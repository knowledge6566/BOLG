# ============================================================
# BOLGERR ENVIRONMENT CONFIGURATION
# Copy this to .env and update with your values
# ============================================================

# Server Configuration
NODE_ENV=development                    # development or production
PORT=3000                              # Server port
HOST=0.0.0.0                           # Server host

# Database (if migrating from JSON to SQL)
DB_TYPE=sqlite                         # sqlite, mysql, postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bolgerr
DB_USER=bolgerr_user
DB_PASSWORD=secure_password_here
DB_TIMEZONE=UTC

# CORS & Security
CORS_ORIGIN=http://localhost:3000      # In production: https://yourdomain.com
CORS_CREDENTIALS=true
API_RATE_LIMIT=100                     # Requests per hour

# Email Configuration (for contact form & newsletter)
SMTP_HOST=smtp.gmail.com               # SMTP server
SMTP_PORT=587                          # SMTP port
SMTP_USER=your-email@gmail.com         # Email address
SMTP_PASSWORD=app_password_here        # App-specific password
SMTP_FROM=noreply@bolgerr.com         # Sender email
SMTP_FROM_NAME=Bolgerr

# Email Recipients
CONTACT_EMAIL=hello@bolgerr.com        # Where contact submissions go
ADMIN_EMAIL=admin@bolgerr.com          # Admin email for alerts

# Authentication (for admin endpoints)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=secure_admin_password
API_KEY=your_api_key_here

# Third-Party Services
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX       # Google Analytics property ID
SENTRY_DSN=                            # Error tracking (Sentry)
CLOUDINARY_CLOUD_NAME=                 # Image hosting
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# AWS (if hosting on AWS)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=bolgerr-uploads

# Backup & Storage
BACKUP_DIR=./backups
BACKUP_FREQUENCY=daily                 # daily or weekly
BACKUP_RETAIN_DAYS=30

# Feature Flags
FEATURE_COMMENTS=true                  # Enable comments on posts
FEATURE_SEARCH=true                    # Enable search functionality
FEATURE_DARK_MODE=false                # Enable dark mode toggle
FEATURE_SOCIAL_SHARE=true              # Enable social share buttons
FEATURE_ANALYTICS=true                 # Track user analytics
FEATURE_EMAIL_SIGNUP=true              # Enable email signup

# Site Configuration
SITE_NAME=Bolgerr
SITE_DESCRIPTION=Thoughtful writing on technology, design, and culture
SITE_URL=https://bolgerr.com
SITE_LOGO_URL=https://bolgerr.com/logo.png
SITE_FAVICON_URL=https://bolgerr.com/favicon.ico

# Blog Settings
POSTS_PER_PAGE=12
FEATURED_POSTS_COUNT=3
RELATED_POSTS_COUNT=5
COMMENTS_PER_PAGE=20
MODERATION_REQUIRED=true

# Newsletter
MAILCHIMP_API_KEY=                     # MailChimp integration
MAILCHIMP_LIST_ID=
NEWSLETTER_SUBJECT=Bolgerr Weekly       # Default newsletter subject
NEWSLETTER_SEND_DAY=Friday              # When to send newsletters

# Social Media
TWITTER_HANDLE=@bolgerr_blog
INSTAGRAM_HANDLE=bolgerr_blog
LINKEDIN_URL=https://linkedin.com/company/bolgerr
GITHUB_URL=https://github.com/bolgerr

# Development
DEBUG=false                             # Enable debug mode
LOG_LEVEL=info                          # error, warn, info, debug
SEED_DATABASE=true                      # Auto-seed with sample data

# Cache Configuration
CACHE_ENABLED=true
CACHE_TTL=3600                          # Cache time-to-live in seconds
CACHE_TYPE=memory                       # memory or redis

# Redis (if using Redis for caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# File Upload
MAX_FILE_SIZE=5242880                   # 5MB in bytes
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf,doc,docx
UPLOAD_DIR=./uploads

# Security
JWT_SECRET=your_jwt_secret_key_here     # For authentication
JWT_EXPIRE=7d                           # Token expiration
SESSION_SECRET=your_session_secret

# Rate Limiting
RATE_LIMIT_CONTACT=5                    # Max contact forms per hour
RATE_LIMIT_NEWSLETTER=10                # Max subscriptions per hour
RATE_LIMIT_API=100                      # Max API calls per hour

# Logging
LOG_FILE=./logs/app.log
LOG_MAX_SIZE=10m                        # Max log file size
LOG_MAX_FILES=14                        # Max log files to keep

# Production
ENFORCE_HTTPS=true                      # Redirect HTTP to HTTPS
HSTS_MAX_AGE=31536000                   # HSTS max age in seconds
CSP_ENABLED=true                        # Content Security Policy
X_FRAME_OPTIONS=DENY                    # Clickjacking protection
X_CONTENT_TYPE_OPTIONS=nosniff          # MIME sniffing protection

# Maintenance
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=We're currently undergoing maintenance
MAINTENANCE_UNTIL=2025-12-31T23:59:59Z

# ============================================================
# NOTES:
# - Never commit this file with real values to Git
# - Use .env.local for local development
# - In production, set environment variables on the server
# - Example: export PORT=3000
# ============================================================
