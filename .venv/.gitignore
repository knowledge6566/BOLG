*# ============================================
#   BOLG Project — .gitignore
#   Safe to publish: code only, no data/secrets
# ============================================


# ----------------------------
# 🔴 USER DATA — NEVER UPLOAD
# ----------------------------
data/
*.csv
# Keep package.json but block other json data files
data/*.json
contacts.json
posts.json


# ----------------------------
# 🔴 SECRET KEYS & PASSWORDS
# ----------------------------
.env
.env.local
.env.production
.env.development
*.pem
*.key
secrets.json
config/secrets.*


# ----------------------------
# 🟡 NODE.JS
# ----------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.node_repl_history
dist/
build/
.cache/


# ----------------------------
# 🟡 PYTHON
# ----------------------------
.venv/
venv/
env/
ENV/
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
*.egg
.pytest_cache/
.mypy_cache/
instance/
.webassets-cache
celerybeat-schedule
*.sqlite3
*.db


# ----------------------------
# 🟡 MACOS SYSTEM FILES
# ----------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db


# ----------------------------
# 🟡 VS CODE
# ----------------------------
.vscode/settings.json
.vscode/launch.json
# Keep .vscode/extensions.json if you want to share recommended extensions


# ----------------------------
# 🟢 THESE ARE SAFE TO UPLOAD
# ----------------------------
# ✅ admin.html
# ✅ index.html
# ✅ server.js
# ✅ server-python.py
# ✅ setup.sh
# ✅ package.json
# ✅ package-lock.json
# ✅ requirements.txt
# ✅ README.md
# ✅ db-schema.sql
# ✅ API-DOCUMENTATION.md
# ✅ DEPLOYMENT.md
# ✅ .env.example  (fake/sample values only!)
# ✅ include/
# ✅ lib/